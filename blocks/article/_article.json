        },
        {
          "component": "select",
          "name": "style",
          "label": "Card Style",
          "valueType": "string",
          "value": "default",
          "options": [
            { "name": "Default", "value": "default" },
            { "name": "Image Top", "value": "image-top" },
            { "name": "Image Bottom", "value": "image-bottom" },
            { "name": "Image Left", "value": "image-left" },
            { "name": "Image Right", "value": "image-right" },
            { "name": "Teaser Overlay", "value": "teaser-overlay" },
            { "name": "Teaser Card", "value": "teaser-card" }
          ]
        },
        {
          "component": "select",
          "name": "ctastyle",
          "label": "CTA Style",
          "valueType": "string",
          "value": "button",
          "options": [
            { "name": "Primary Button", "value": "button" },
            { "name": "Secondary Button", "value": "button-secondary" },
            { "name": "Dark Button", "value": "button-dark" }
